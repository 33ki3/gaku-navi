    "md": {
      "close_button": "w-8 h-8 flex items-center justify-center rounded-full hover:bg-black/10 text-slate-500",
      "close_icon": "w-4 h-4",
      "toggle": "px-3 py-1 text-xs"
    },
    "lg": {
      "close_button": "w-8 h-8 flex items-center justify-center rounded-full hover:bg-black/10 text-slate-500",
      "close_icon": "w-5 h-5",
      "toggle": "px-4 py-1.5 text-xs"
    }
